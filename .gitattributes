# Driftless line-ending policy.
# Windows scripts are CRLF so Windows PowerShell 5.1 parses them and git does
# not emit "LF will be replaced by CRLF" warnings that could pollute gate output.
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# POSIX shell stays LF.
*.sh text eol=lf

# Docs / data: normalize to LF in the repo, let git handle checkout.
*.md text
*.json text
*.txt text

# Treat unknown binary safely.
* text=auto
