# Driftless — containment-first .gitignore
# Never track runtime state, secrets, host-global config, or account material.

# Runtime / materialized profiles (regenerated by install; never committed)
.runtime/
.codex-work/
runtime-home/
*-home/

# Secrets / credentials / keys
.env
.env.*
*.pem
*.key
id_rsa
id_ed25519
secrets/
**/secrets/
.ssh/
**/.ssh/

# Cloud / account state
.aws/
.gcloud/
accounts/
**/accounts/

# Browser profiles
browser-profile/
browser-profiles/

# Logs and scratch
logs/
*.log
.scratch/
tmp/
*.tmp

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Node (if any tooling is added later)
node_modules/

# Internal maintainer strategy — never public (application/promo are not product docs)
docs/application/
docs/community/
docs/**/promotion-strategy.md
docs/**/codex-for-oss-application.md
docs/**/ecosystem-role.md
docs/ko/홍보-전략.md
